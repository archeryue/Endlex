# Endlex server environment. Copy to /etc/endlex/env (chmod 0600, owner endlex).

# Bearer token required on write endpoints. Generate with:
#   python -c 'import secrets; print(secrets.token_urlsafe(32))'
ENDLEX_TOKEN=replace-me

# Data tree (runs/, checkpoints/). Must exist and be writable by the service user.
ENDLEX_DATA=/var/lib/endlex

# Set to 0 to require the bearer token on read endpoints too (HTML dashboard
# + JSON reads). Default 1 (public reads behind your nginx/cert).
ENDLEX_PUBLIC_READS=1

# Port uvicorn binds. Default 8000. nginx in front handles 443.
ENDLEX_PORT=8000

# ---- Checkpoint retention (server-wide defaults) ----
# 0 means "no limit on that dimension". Per-run state.json can override
# either value via {"retention": {"keep_last": N, "max_age_days": D}}.

# Keep only the N most recent checkpoints per run. 0 = keep all.
ENDLEX_CKPT_KEEP_LAST=0

# Delete checkpoints whose directory is older than D days. 0 = no age limit.
# Pruning runs after each upload, and on the POST /api/admin/prune endpoint
# (suitable for an hourly cron from the home box).
ENDLEX_CKPT_MAX_AGE_DAYS=0
